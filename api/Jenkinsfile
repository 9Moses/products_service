pipeline {
    agent {
        docker {
            image 'docker:24.0.5-cli'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10', daysToKeepStr: '30'))
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }

    environment {
        REGISTRY = 'ghcr.io'
        REGISTRY_NAMESPACE = '9moses'
        REGISTRY_CREDENTIALS = 'ghcr-registry-credentials'

        API_IMAGE = "${REGISTRY}/${REGISTRY_NAMESPACE}/rest-api:${BUILD_NUMBER}"
        LATEST_API_IMAGE = "${REGISTRY}/${REGISTRY_NAMESPACE}/rest-api:latest"

        BUILD_ENV = "${WORKSPACE}/build"
        DOCKER_BUILDKIT = '1'
        DOCKER_CLI_EXPERIMENTAL = 'enabled'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh '''
                    docker build \
                        --tag ${API_IMAGE} \
                        --tag ${LATEST_API_IMAGE} \
                        --build-arg BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) \
                        --build-arg VCS_REF=$(git rev-parse --short HEAD) \
                        --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                        -f Dockerfile .
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                sh '''
                    docker run --rm \
                        --volume ${WORKSPACE}:/app \
                        --workdir /app \
                        ${LATEST_API_IMAGE} \
                        bash -c "python manage.py test --verbosity=2 || true"
                '''
            }
        }

        stage('Quality') {
            steps {
                sh '''
                    docker run --rm \
                        --volume ${WORKSPACE}:/app \
                        --workdir /app \
                        ${LATEST_API_IMAGE} \
                        bash -c "pip install flake8 pylint && \
                                 flake8 . --max-line-length=120 --exclude=migrations || true && \
                                 pylint **/*.py --disable=all --enable=E,F || true"
                '''
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                    docker run --rm \
                        --volume ${WORKSPACE}:/app \
                        --workdir /app \
                        ${LATEST_API_IMAGE} \
                        bash -c "pip install safety && safety check --json || true"
                '''
            }
        }

        stage('Push') {
            when {
                expression { env.GIT_BRANCH == 'origin/main' }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${REGISTRY_CREDENTIALS}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo ${DOCKER_PASS} | docker login ghcr.io -u ${DOCKER_USER} --password-stdin
                        docker push ${API_IMAGE}
                        docker push ${LATEST_API_IMAGE}
                        docker logout
                    '''
                }
            }
        }

        stage('Deploy') {
            when {
                expression { env.GIT_BRANCH == 'origin/main' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        export KUBECONFIG=${KUBECONFIG_FILE}
                        kubectl apply -f api/k8s -n rest-microservice
                    '''
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh '''
                    docker rmi ${API_IMAGE} || true
                    docker rmi ${LATEST_API_IMAGE} || true
                    docker system prune -f || true
                    rm -rf ${BUILD_ENV}/* 2>/dev/null || true
                    mkdir -p ${BUILD_ENV}
                '''
            }
        }
    }

    post {
        always {
            sh 'docker images | grep rest-api || true'
        }
        success {
            echo "API service build #${BUILD_NUMBER} succeeded"
        }
        failure {
            echo "API service build #${BUILD_NUMBER} failed"
        }
    }
}